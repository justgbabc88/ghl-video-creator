# Supabase (provisioned by Cowork agent — values printed when project is created)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgres://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Anthropic Claude (script generation)
ANTHROPIC_API_KEY=

# ElevenLabs (TTS narration)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel — default; override per-account in DB

# YouTube Data API v3 — OAuth 2.0 (user runs the consent flow once, then we store refresh token)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/oauth/callback

# GHL session for screen recording (added per-account in DB; this is the fallback)
GHL_LOGIN_EMAIL=
GHL_LOGIN_PASSWORD=
GHL_LOCATION_ID=

# Slack webhook for status pings (optional)
SLACK_WEBHOOK_URL=

# Resend for failure-escalation email (optional)
RESEND_API_KEY=
RESEND_FROM=alerts@yourdomain.com
ALERT_TO_EMAIL=

# Worker config
NODE_ENV=production
LOG_LEVEL=info
DETECT_INTERVAL_MIN=30           # how often to poll GHL changelog
PER_VIDEO_BUDGET_USD=1.5         # hard cap; pipeline aborts if a single video exceeds this
REVIEW_REQUIRED_DEFAULT=true     # videos go to dashboard for approval before publishing
